# SAM frontend environment template.
# Copy to .env.local for local dev. Set the same vars in Vercel project
# settings for production / preview deployments.

# Public — visible to the browser. Always /api in this app; the value is
# rewritten by next.config.ts to BACKEND_URL on the server side, then
# proxied through to the SAM backend.
NEXT_PUBLIC_API_BASE=/api

# Server-only — where Next.js rewrites /api/* requests to.
#   Local dev:   http://localhost:5500
#   Production:  https://sam.gazonindia.com   (or whatever the SAM VM URL is)
BACKEND_URL=http://localhost:5500
